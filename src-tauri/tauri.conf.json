{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BR-Log",
  "version": "1.1.1",
  "identifier": "de.betriebsrat.brzeiten",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BR-Log",
        "width": 1100,
        "height": 780,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "copyright": "© 2026 Mario König. Alle Rechte vorbehalten.",
    "publisher": "Mario König",
    "shortDescription": "Betriebsrats-Zeiterfassung",
    "longDescription": "Lokale Zeiterfassung für Betriebsratsmitglieder mit strikter Trennung von Geschäftsleitungs-Informationen und vertraulichen Tätigkeitsdetails (BR-Geheimnis).",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "wix": {}
    }
  },
  "plugins": {}
}
