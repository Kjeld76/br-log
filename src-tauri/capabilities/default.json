{
  "identifier": "default",
  "description": "Standard-Berechtigungen für das Hauptfenster",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-theme",
    "os:default",
    "notification:default",
    "opener:allow-reveal-item-in-dir",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$APPCONFIG" },
        { "path": "$APPCONFIG/**" },
        { "path": "$EXE/BR-Log-Data" },
        { "path": "$EXE/BR-Log-Data/**" }
      ]
    },
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://ko-fi.com/*" },
        { "url": "https://buymeacoffee.com/*" }
      ]
    }
  ]
}
